# Agent runtime env. Copy to .env (gitignored) and fill what you need.
# Nothing here is required for `pytest`, `mypy`, or the default-source
# `praxis backtest --source binance` — that runs entirely offline-capable.

# --- LLM meta-policy (optional) -------------------------------------------
# Set this to enable LLMMetaPolicy via LangGraph. If unset, the engine uses
# the deterministic RuleBasedPolicy fallback (and tests pass without it).
# OPENAI_API_KEY=sk-...

# --- CoinGecko alternate price source (optional) ---------------------------
# Free demo-tier key from https://www.coingecko.com/en/api/pricing.
# Only needed if you pass `--source coingecko` to the CLI.
# COINGECKO_API_KEY=CG-...

# --- Live execution (intentionally disabled by default) --------------------
# CDPExecutor.execute() raises NotImplementedError until a future opt-in
# CLI flag is added. Setting these here does NOT enable live trading.
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# --- Paper-trade FastAPI server (optional) ---------------------------------
# Bind address for `praxis.server:app` (Phase v0.2 wiring). The Next.js
# operator terminal reads this from NEXT_PUBLIC_API_URL on the client side.
# PRAXIS_SERVER_HOST=0.0.0.0
# PRAXIS_SERVER_PORT=8000
