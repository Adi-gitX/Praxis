# Contracts deployment env vars.
# Copy to .env (which is .gitignored) before running `npx hardhat ignition deploy`.
# Without these set, `npx hardhat compile` and `npx hardhat test` still work
# (they fall back to a dummy key — see hardhat.config.ts).

# 32-byte hex private key of the deployer EOA. Funded with Base Sepolia ETH
# from https://www.alchemy.com/faucets/base-sepolia for testnet deploys.
WALLET_KEY=0xREPLACE_ME_WITH_YOUR_DEPLOYER_PRIVATE_KEY

# Optional — only needed for `npx hardhat verify` after a deploy.
# Get a free key at https://basescan.org/myapikey
ETHERSCAN_API_KEY=

# Optional — alternative RPCs if the public Base Sepolia endpoint rate-limits.
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
